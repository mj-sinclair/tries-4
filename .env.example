# ============================================================
# PropManager KE — Environment Variables
# Copy to .env, fill in your values. NEVER commit .env to Git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development          # change to: production
PORT=3000
SERVER_URL=https://your-app.railway.app   # your deployed URL

# ── M-Pesa Daraja ────────────────────────────────────────────
DARAJA_KEY=your_consumer_key
DARAJA_SECRET=your_consumer_secret
MPESA_PAYBILL=174379          # your Paybill or Till number

# ── Africa's Talking SMS ─────────────────────────────────────
AT_API_KEY=your_api_key
AT_USERNAME=sandbox           # use 'sandbox' for testing; your username for production
AT_SENDER_ID=PROPMANAGER      # register this in AT dashboard

# ── SUPABASE (use with supabase/server.js) ───────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key   # NOT the anon key — use service key on server

# ── FIREBASE (use with firebase/server.js) ───────────────────
# Paste contents of serviceAccountKey.json as a single-line JSON string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── SQLITE (use with sqlite/server.js) ───────────────────────
DB_PATH=./propmanager.db      # path to SQLite file
BACKUP_KEY=change_this_secret_key   # used to protect /api/backup endpoint
